generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(VIEWER)
  status    Status   @default(ACTIVE)
  records   Record[]
  createdAt DateTime @default(now())
}

model Record {
  id        String      @id @default(cuid())
  amount    Decimal     @db.Decimal(12, 2)
  type      RecordType
  category  String
  date      DateTime
  note      String?
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  deletedAt DateTime?

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([category])
  @@index([deletedAt])
}